<!-- Sección Sobre Nosotros -->
<section id="about" class="about">
  <div class="about__container">
    <div class="about__layout">

      <!-- Columna izquierda: galería + stats -->
      <div class="about__left">

        <!-- Galería de imágenes — efecto fan/abanico -->
        <div class="about__gallery">
          <img class="about__img about__img--back"
               src="/images/fabrica2.png"
               alt="Interior de la planta PLASTIMET — líneas de extrusión de PVC"
               width="1536"
               height="1024"
               loading="lazy" />
          <img class="about__img about__img--front"
               src="/images/fabrica1.png"
               alt="Planta industrial PLASTIMET en Naschel, San Luis — vista principal"
               width="1536"
               height="1024"
               loading="lazy" />
        </div>

        <!-- Stats en fila debajo de las imágenes -->
        <div class="about__stats">
          <div class="about__stat">
            <div class="about__stat-number-wrapper">
              <span class="about__stat-number" data-target="65">0</span>
              <span class="about__stat-suffix">+</span>
            </div>
            <div class="about__stat-line"></div>
            <span class="about__stat-label">Años de experiencia</span>
          </div>
          <div class="about__stat">
            <div class="about__stat-number-wrapper">
              <span class="about__stat-number" data-target="1960">0</span>
            </div>
            <div class="about__stat-line"></div>
            <span class="about__stat-label">Año de fundación</span>
          </div>
          <div class="about__stat">
            <div class="about__stat-number-wrapper">
              <span class="about__stat-number" data-target="6">0</span>
              <span class="about__stat-suffix">+</span>
            </div>
            <div class="about__stat-line"></div>
            <span class="about__stat-label">Marcas líderes</span>
          </div>
          <div class="about__stat">
            <div class="about__stat-number-wrapper">
              <span class="about__stat-number" data-target="2">0</span>
            </div>
            <div class="about__stat-line"></div>
            <span class="about__stat-label">Sedes en Argentina</span>
          </div>
        </div>

      </div>

      <!-- Columna derecha: texto -->
      <div class="about__content">
        <div class="about__content-card">
          <h2 class="about__title about__clip-reveal">Sobre Nosotros</h2>
          <p class="about__text about__clip-reveal">
            Desde 1960, <strong>PLASTIMET San Luis S.A.</strong> combina una
            sólida y reconocida trayectoria promoviendo la calidad con una
            visión flexible e innovadora del mercado. Nuestras marcas lideran
            la industria nacional de la extrusión de productos de PVC.
          </p>

          <h3 class="about__subtitle about__clip-reveal">Nuestras Instalaciones</h3>
          <p class="about__text about__clip-reveal">
            Desde nuestra planta industrial en Naschel, Provincia de San Luis,
            y nuestro centro logístico y comercial en Bella Vista, Provincia de
            Buenos Aires, elaboramos y comercializamos una amplia gama de
            productos para consumo interno y exportación.
          </p>

          <h3 class="about__subtitle about__clip-reveal">Alianzas Internacionales</h3>
          <p class="about__text about__clip-reveal">
            Desde 2006, somos representantes exclusivos en Argentina de
            <strong>Norres Schlauchtechnik</strong>, líder mundial en mangueras
            industriales de alta tecnología para las más exigentes aplicaciones.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
