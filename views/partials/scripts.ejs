<!-- Globe.gl JS -->
<script src="https://cdn.jsdelivr.net/npm/globe.gl@2.41.0/dist/globe.gl.min.js"></script>

<!-- Swiper.js -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<!-- JavaScript del cliente (debe cargar después de las librerías) -->
<script src="/js/main.js"></script>

<!-- Inicializar Swiper Hero Carousel -->
<script>
  const heroSwiper = new Swiper('.hero__carousel', {
    autoplay: {
      delay: 3000,
      disableOnInteraction: false,
    },
    speed: 1000,
    effect: 'slide',
    loop: true,
    allowTouchMove: false,
    noSwiping: true,
  });
</script>

